# ==============================================================================
# apps/api-gateway/.env.local.template — API Gateway vars for LOCAL dev (no Docker)
# ==============================================================================
#
# Use this when running api-gateway standalone without Docker:
#   cp apps/api-gateway/.env.local.template apps/api-gateway/.env
#   cd apps/api-gateway && npm run start:dev
#
# When using Docker Compose, this file is also read via env_file: in
# docker-compose.dev.yml — Docker-internal URLs override the localhost ones.
#
# NOTE: JWT_SECRET is not here. Copy it manually from infra/compose/.env.shared.template
#       because auth-service must use the exact same value.
# ==============================================================================


# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:5173


# ── Downstream service URLs (local dev, no Docker) ─────────────────────────────
# Each service runs on its own port on localhost.
# In Docker these become http://<service-name>:<port> automatically.
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
AGENT_SERVICE_URL=http://localhost:3003
AI_CORE_URL=http://localhost:3004
DOCUMENT_SERVICE_URL=http://localhost:3005
WORKFLOW_SERVICE_URL=http://localhost:3006
INTEGRATION_SERVICE_URL=http://localhost:3007
ML_PIPELINE_URL=http://localhost:3008


# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
