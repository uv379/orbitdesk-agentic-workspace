# ==============================================================================
# auth-service/.env.local.template — Environment variables for auth-service
# ==============================================================================
#
# HOW TO USE:
#   cp .env.local.template .env
#   Fill in the values in .env
#   .env is gitignored — never commit it
#
# In Docker (docker-compose), these are set via the `environment:` block
# in docker-compose.dev.yml. The .env file is only for running locally
# without Docker (e.g., `uvicorn app.main:app --reload`).
# ==============================================================================

# ── Database ───────────────────────────────────────────────────────────────────
# NOTE: "+asyncpg" is required — tells SQLAlchemy to use the async driver.
# Local (without Docker):  postgresql+asyncpg://postgres:password@localhost:5432/orbitdesk_auth
# Inside Docker network:   set in docker-compose.dev.yml using POSTGRES_* vars
DATABASE_URL=postgresql+asyncpg://orbitdesk:yourpassword@localhost:5432/orbitdesk_auth

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must match the JWT_SECRET in infra/compose/.env (shared with api-gateway).
# Generate: openssl rand -hex 64
JWT_SECRET=e06587cb91a36a3a431c1eb83490d12128d2a5ff24e24c86ef210300d5651d2a7163687985b2c7e9707a60e01e7c1b87ae3331803b980a6400ec010daffa27b2


# How long access tokens live. Format: 15m, 1h, 7d
JWT_ACCESS_EXPIRES=15m

# How long refresh tokens live.
JWT_REFRESH_EXPIRES=7d

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# Set to True to print all SQL queries to the console (useful for debugging).
DEBUG=False
