# ==============================================================================
# infra/compose/.env.shared.template — Shared secrets used by 2+ services
# ==============================================================================
#
# HOW TO USE:
#   cp infra/compose/.env.shared.template infra/compose/.env
#   Fill in real values in .env
#   .env is gitignored — never commit it
#
# RULE: A var lives here ONLY if 2+ services need the same value.
#       Gateway-specific vars → apps/api-gateway/.env.local.template
#       Other service vars    → apps/services/<name>/.env.local.template
#
# GENERATE SECRETS:
#   JWT_SECRET:      node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   POSTGRES_PASS:   openssl rand -base64 32
# ==============================================================================


# ── JWT ────────────────────────────────────────────────────────────────────────
# api-gateway  → verify tokens (reads this)
# auth-service → sign tokens  (reads this)
# Must be identical in both — one change here updates both at once.
JWT_SECRET=


# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# One shared Postgres server. Each service gets its own database.
# docker-compose.infra.yml starts the server using these creds.
# Each service builds its own DATABASE_URL from these vars.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=orbitdesk
POSTGRES_PASSWORD=


# ── Redis ──────────────────────────────────────────────────────────────────────
# Shared by: agent-service (queues), workflow-service (queues),
#            ai-core-service (context cache), api-gateway (rate limit in prod)
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=        # uncomment if you enable requirepass in redis.conf


# ── Message Brokers ────────────────────────────────────────────────────────────
# Kafka — high-throughput event streaming (agent events, audit logs)
KAFKA_BROKER=kafka:9092

# RabbitMQ — task queues for reliable job dispatch between services
RABBITMQ_URL=amqp://orbitdesk:changeme@rabbitmq:5672


# ── Object Storage (S3-compatible) ─────────────────────────────────────────────
# Local dev:   MinIO runs in Docker (docker-compose.infra.yml)
# Production:  swap S3_ENDPOINT to https://s3.amazonaws.com, use real AWS creds
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=
S3_BUCKET_DOCUMENTS=orbitdesk-documents
S3_BUCKET_MODELS=orbitdesk-models


# ── AI / LLM ───────────────────────────────────────────────────────────────────
# Only ai-core-service reads this — listed here because it's a secret that
# needs coordinated rotation across environments.
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-


# ── Note: gateway-specific vars ────────────────────────────────────────────────
# CORS_ORIGIN, RATE_LIMIT_WINDOW_MS, RATE_LIMIT_MAX, PORT, and all service URLs
# live in apps/api-gateway/.env.local.template — only the gateway needs them.
# Do not add them here.
